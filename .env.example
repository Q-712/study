# 知境文本分析系统 - 环境变量配置

# Flask 配置
SECRET_KEY=your-secret-key-here-keep-it-secure
FLASK_ENV=production

# 数据库配置（Railway 会自动设置 DATABASE_URL）
# 本地开发使用 SQLite，部署到 Railway 时会自动使用 PostgreSQL
# DATABASE_URL=postgresql://user:password@host:port/database

# AI服务配置
DASHSCOPE_API_KEY=your-aliyun-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus

# 备用配置（留空即可）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# 默认服务设置
DEFAULT_AI_SERVICE=aliyun
ENCRYPTION_KEY=your-encryption-key-here-change-this-in-production